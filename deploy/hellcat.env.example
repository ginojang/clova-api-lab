# hellcat ~/apps/clova-api-lab/.env — 백엔드 전용. 절대 커밋 금지(저장소 외부).
# 터널 전용이라 loopback 바인드.
PORT=3600
HOST=127.0.0.1

# CLOVA Studio 자격증명 (배포 후 실제 값 입력 → systemctl restart)
CLOVA_AUTH_MODE=legacy
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com
CLOVA_API_KEY=
CLOVA_APIGW_API_KEY=
# CLOVA_CHAT_PATH=

# ── 벤치 영속화용 MySQL (clova_lab). 미설정 시 벤치 비활성, 채팅은 정상 ──
DB_HOST=192.168.0.2
DB_PORT=3306
DB_USER=gino
DB_PASSWORD=
DB_NAME=clova_lab

# 항목별 평가에 쓰는 Claude CLI 경로(hellcat의 인증된 claude)
CLAUDE_BIN=/home/gino/.local/bin/claude
# CLAUDE_JUDGE_MODEL=

# TEI 게이트웨이 부하 생성기 기본 타깃(미설정 시 p38)
TEI_URL=http://192.168.0.18:8000

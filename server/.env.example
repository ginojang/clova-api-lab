# server/.env — 백엔드 전용. 실제 server/.env 는 커밋 금지(.gitignore 처리됨).
PORT=3600

# CLOVA Studio 자격증명 (legacy X-NCP-* 방식)
CLOVA_API_KEY=
CLOVA_APIGW_API_KEY=
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com

# (배포 시) spitfire PostgreSQL — 로그 영속화용. 실제 값은 hellcat 의 server/.env 에만.
# PGHOST=192.168.0.2
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=

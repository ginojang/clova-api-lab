# server/.env — 백엔드 전용. 실제 server/.env 는 커밋 금지(.gitignore 처리됨).
PORT=3600

# CLOVA Studio 자격증명
CLOVA_API_KEY=
CLOVA_APIGW_API_KEY=
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com

# 인증 방식: legacy(X-NCP-* 두 키) | bearer(Authorization: Bearer, 현행 v3)
CLOVA_AUTH_MODE=legacy
# 엔드포인트 경로 override (미설정 시 모드별 기본값: legacy=/testapp/v1/chat-completions, bearer=/v3/chat-completions)
# CLOVA_CHAT_PATH=

# (배포 시) spitfire PostgreSQL — 로그 영속화용. 실제 값은 hellcat 의 server/.env 에만.
# PGHOST=192.168.0.2
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
